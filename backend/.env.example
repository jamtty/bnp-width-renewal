# DB 접속 정보
DB_HOST=localhost
DB_NAME=your_database
DB_USER=your_username
DB_PASS=your_password
DB_CHARSET=utf8mb4

# 업로드 URL (게시판별 파일첨부 URL 접두어)
UPLOAD_URL=/uploads/news/
UPLOAD_URL_REPORT=/uploads/report/
UPLOAD_URL_NOTICE=/uploads/notice/
UPLOAD_URL_MAIN_BANNER=/uploads/main_banner/

# 에디터 이미지 업로드 URL
UPLOAD_URL_EDITOR=/uploads/editor/

# CORS 허용 도메인 (* 또는 특정 도메인)
CORS_ORIGIN=*
