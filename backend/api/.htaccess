# 디렉토리 목록 비공개
Options -Indexes

# PHP 업로드/메모리 설정 (mod_php 환경)
<IfModule mod_php8.c>
    php_value upload_max_filesize 20M
    php_value post_max_size      25M
    php_value memory_limit       256M
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 20M
    php_value post_max_size      25M
    php_value memory_limit       256M
</IfModule>

# 모든 요청을 index.php로 라우팅
<IfModule mod_rewrite.c>
    RewriteEngine On
    DirectorySlash Off
    RewriteBase /backend/api/

    # Authorization 헤더를 PHP로 전달 (Apache가 기본 차단)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # PUT, DELETE, PATCH는 파일 체크 없이 바로 index.php로 전달
    RewriteCond %{REQUEST_METHOD} ^(PUT|DELETE|PATCH)$
    RewriteRule ^(.*)$ index.php [QSA,L]

    # index.php 본인만 직접 접근 허용, 나머지 PHP 파일은 index.php로 전달
    RewriteCond %{REQUEST_FILENAME} !-f [OR]
    RewriteCond %{REQUEST_FILENAME} \.php$
    RewriteCond %{REQUEST_URI} !=/backend/api/index.php

    # 나머지는 index.php로 전달
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# index.php 외 PHP 파일 직접 접근 차단
<FilesMatch "^(?!index\.php$).+\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>
